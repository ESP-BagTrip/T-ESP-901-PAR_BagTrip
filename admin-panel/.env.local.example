# Admin Panel — Local Development
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>

# Prefix applied to auth cookie names. Leave empty in prod; set to e.g. `dev_`
# in preprod so prod cookies (.bagtrip.fr) don't leak to sub-domains
# (dev.bagtrip.fr) under a different JWT_SECRET.
# MUST match the API's COOKIE_NAME_PREFIX for the same environment.
NEXT_PUBLIC_COOKIE_NAME_PREFIX=
