{
  "name": "front_admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 8000",
    "dev:coverage": "CYPRESS_COVERAGE=true next dev -p 8000",
    "build": "next build --turbopack",
    "start": "next start -p 8000",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "check-all": "npm run type-check && npm run lint && npm run format:check",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:headless": "cypress run --headless",
    "cypress:run:ci": "cypress run --headless --reporter cypress-multi-reporters --reporter-options configFile=reporter-config.json",
    "test:e2e": "start-server-and-test dev http://localhost:8000 cypress:run",
    "test:e2e:open": "start-server-and-test dev http://localhost:8000 cypress:open",
    "test:e2e:ci": "start-server-and-test dev http://localhost:8000 cypress:run:ci",
    "test:e2e:coverage": "CYPRESS_COVERAGE=true start-server-and-test dev:coverage http://localhost:8000 cypress:run:ci",
    "report:junit:merge": "npx junit-merge -d cypress/reports/junit -o cypress/reports/sonar-report.xml",
    "sonar:prepare": "npm run test:e2e:ci && npm run report:junit:merge"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.7",
    "@heroicons/react": "^2.2.0",
    "@stripe/stripe-js": "^8.6.0",
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-query-devtools": "^5.87.4",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.11.0",
    "clsx": "^2.1.1",
    "cookies-next": "^6.1.0",
    "date-fns": "^4.1.0",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.542.0",
    "next": "15.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.62.0",
    "recharts": "^3.1.2",
    "swr": "^2.3.6"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.28.4",
    "@cypress/code-coverage": "^3.14.6",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "autoprefixer": "^10.4.21",
    "babel-plugin-istanbul": "^7.0.1",
    "cypress": "^15.0.0",
    "cypress-multi-reporters": "^2.0.5",
    "eslint": "^9",
    "eslint-config-next": "15.5.0",
    "mocha-junit-reporter": "^2.2.1",
    "nyc": "^17.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "start-server-and-test": "^2.0.13",
    "swc-plugin-coverage-instrument": "^0.0.32",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
