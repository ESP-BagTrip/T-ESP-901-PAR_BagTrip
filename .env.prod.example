# BagTrip — Production Environment
# All variables required unless marked (optional).

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=<strong-username>
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=bagtrip
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/bagtrip

# ── Amadeus (https://developers.amadeus.com) ─────────────────
AMADEUS_CLIENT_ID=<production-client-id>
AMADEUS_CLIENT_SECRET=<production-client-secret>
AMADEUS_BASE_URL=https://api.amadeus.com

# ── LLM (OVH GPT-OSS) ───────────────────────────────────────
LLM_MODEL=gpt-oss-120b
LLM_API_BASE=https://oai.endpoints.kepler.ai.cloud.ovh.net/v1
LLM_API_KEY=<production-llm-api-key>

# ── Auth / JWT ───────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=<strong-random-secret-min-64-chars>
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Stripe (live keys) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_<...>
STRIPE_WEBHOOK_SECRET=whsec_<...>

# ── OAuth ────────────────────────────────────────────────────
GOOGLE_FIREBASE_PROJECT_ID=bagtrip-7d2d8
GOOGLE_OAUTH_CLIENT_ID=<google-oauth-client-id>
APPLE_BUNDLE_ID=<apple-bundle-id>

# ── LangSmith (optional) ────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=<langsmith-api-key>
LANGCHAIN_PROJECT=BagTrip

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
