# Dockerfile.dev pour l'API Python BagTrip
FROM python:3.14-slim

# Définir le répertoire de travail
WORKDIR /app

# Installer les outils système nécessaires
RUN apt-get update && apt-get install -y \
    gcc \
    postgresql-client \
    && rm -rf /var/lib/apt/lists/*

# Copier les fichiers de configuration des dépendances
COPY requirements.txt requirements-dev.txt ./

# Créer un environnement virtuel et installer les dépendances
RUN python3 -m venv /app/.venv && \
    /app/.venv/bin/pip install --upgrade pip setuptools wheel && \
    /app/.venv/bin/pip install -r requirements.txt && \
    /app/.venv/bin/pip install -r requirements-dev.txt

# Exposer le port 3000
EXPOSE 3000

# Commande par défaut (sera surchargée par compose.yml)
CMD ["/app/.venv/bin/uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "3000", "--reload"]

