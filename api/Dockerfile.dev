# Dockerfile.dev pour l'API Python BagTrip
FROM python:3.12-slim

# Installer uv en copiant depuis l'image officielle
# Utiliser un stage intermédiaire pour extraire uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /tmp/uv
RUN mv /tmp/uv /usr/local/bin/uv && chmod +x /usr/local/bin/uv

# Définir le répertoire de travail
WORKDIR /app

# Copier les fichiers de configuration des dépendances
COPY pyproject.toml uv.lock ./

# Installer les dépendances avec uv
RUN uv sync --frozen

# Exposer le port 3000
EXPOSE 3000

# Commande par défaut (sera surchargée par compose.yml)
CMD ["uv", "run", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "3000", "--reload"]

