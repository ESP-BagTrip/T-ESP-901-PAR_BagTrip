# Dockerfile.dev (pour le service API)
FROM node:20-alpine AS dev
WORKDIR /app

# Install system tools for Prisma (openssl, etc.)
RUN apk add --no-cache openssl

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy everything
COPY . .

# Run Prisma generation + migration
RUN npx prisma generate

# Expose port
EXPOSE 3000

# Enable file watching in dev
ENV CHOKIDAR_USEPOLLING=true

CMD ["npm", "run", "dev"]
