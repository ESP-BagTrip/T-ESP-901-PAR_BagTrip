# API - Environment
NODE_ENV=development
PORT=8000
REQUEST_TIMEOUT_MS=5000

# API - Database
POSTGRES_USER=user
POSTGRES_PASSWORD=pass
POSTGRES_DB=bagtrip
DATABASE_URL=postgresql://user:pass@localhost:5432/bagtrip

# API - Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API - Amadeus
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# API - Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# API - Google GenAI
GOOGLE_API_KEY=

# API - LangChain / LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT="BagTrip Agents"

# Frontend - Admin Panel (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_NAME=BagTrip Admin
NEXT_PUBLIC_APP_VERSION=1.0.0

# Frontend - Flutter App (BagTrip)
# API_BASE_URL=http://localhost:3000
# STRIPE_PUBLISHABLE_KEY=
