# BagTrip — Dev Environment
# cp .env.example .env && fill in the 3 required keys below.

# Required: Amadeus (https://developers.amadeus.com)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Required: LLM API key (OVH GPT-OSS)
LLM_API_KEY=

# ── Optional (uncomment to override defaults) ────────────────
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=bagtrip
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
