# BagTrip — Dev Environment
# cp .env.example .env && fill in the 3 required keys below.

# Required: Amadeus (https://developers.amadeus.com)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Required: LLM API key (OVH GPT-OSS)
LLM_API_KEY=

# ── Optional (uncomment to override defaults) ────────────────
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=bagtrip
# STRIPE_SECRET_KEY=                       # sk_test_... — required for any Stripe call
# STRIPE_PUBLISHABLE_KEY=                  # pk_test_... — Flutter PaymentSheet (--dart-define injected by Makefile)
# STRIPE_WEBHOOK_SECRET=                   # whsec_... — required in production, recommended in dev (use `make stripe-listen`)
# STRIPE_SUCCESS_URL=bagtrip://subscription/success?session-id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=bagtrip://subscription/cancel
# STRIPE_PORTAL_RETURN_URL=bagtrip://profile
# ENABLE_PLAN_EXPIRATION_JOB=true          # hourly downgrade of expired Premium users
# ENABLE_ZOMBIE_PI_JOB=true                # daily cleanup of stuck AUTHORIZED PaymentIntents
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# UNSPLASH_ACCESS_KEY=
