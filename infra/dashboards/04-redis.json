{
  "annotations": {"list": []},
  "description": "Redis health for BagTrip prod and preprod caches.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "schemaVersion": 39,
  "tags": ["bagtrip", "redis", "cache"],
  "time": {"from": "now-3h", "to": "now"},
  "timezone": "browser",
  "title": "BagTrip — Redis",
  "uid": "bagtrip-redis",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Environment",
        "type": "custom",
        "query": "prod, preprod",
        "current": {"selected": false, "text": "prod", "value": "prod"},
        "options": [
          {"selected": true, "text": "prod", "value": "prod"},
          {"selected": false, "text": "preprod", "value": "preprod"}
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Operations / sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops", "color": {"mode": "palette-classic"}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum(rate(redis_commands_processed_total{env=\"$env\"}[5m]))", "legendFormat": "ops", "refId": "A"}
      ]
    },
    {
      "id": 2,
      "title": "Memory used",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "palette-classic"}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "redis_memory_used_bytes{env=\"$env\"}", "legendFormat": "used", "refId": "A"},
        {"expr": "redis_memory_used_rss_bytes{env=\"$env\"}", "legendFormat": "rss", "refId": "B"}
      ]
    },
    {
      "id": 3,
      "title": "Hit rate",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.8}]}
        }
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total{env=\"$env\"}[5m]) / (rate(redis_keyspace_hits_total{env=\"$env\"}[5m]) + rate(redis_keyspace_misses_total{env=\"$env\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Connected clients",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 9, "x": 6, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "redis_connected_clients{env=\"$env\"}", "legendFormat": "{{env}}", "refId": "A"}
      ]
    },
    {
      "id": 5,
      "title": "Evicted / expired keys",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 9, "x": 15, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "ops", "color": {"mode": "palette-classic"}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "rate(redis_evicted_keys_total{env=\"$env\"}[5m])", "legendFormat": "evicted/s", "refId": "A"},
        {"expr": "rate(redis_expired_keys_total{env=\"$env\"}[5m])", "legendFormat": "expired/s", "refId": "B"}
      ]
    },
    {
      "id": 6,
      "title": "Redis exporter up",
      "type": "stat",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [{"options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}, "type": "value"}],
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"colorMode": "value", "graphMode": "none", "textMode": "value_and_name"},
      "targets": [{"expr": "up{job=\"redis\", env=\"$env\"}", "legendFormat": "{{env}}", "refId": "A"}]
    },
    {
      "id": 7,
      "title": "Keyspace size (total keys)",
      "type": "stat",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value_and_name"},
      "targets": [{"expr": "sum(redis_db_keys{env=\"$env\"})", "refId": "A"}]
    }
  ]
}
