{
  "annotations": {"list": []},
  "description": "Centralised logs from BagTrip-managed containers + edge Caddy access logs. Backed by Loki + Promtail (Phase 2).",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "schemaVersion": 39,
  "tags": ["bagtrip", "logs", "loki"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "BagTrip — Logs",
  "uid": "bagtrip-logs",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {"type": "loki", "uid": "loki"},
        "query": {"label": "service", "type": 1},
        "multi": true,
        "includeAll": true,
        "current": {"selected": false, "text": "All", "value": "$__all"},
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "env",
        "label": "Environment",
        "type": "query",
        "datasource": {"type": "loki", "uid": "loki"},
        "query": {"label": "env", "type": 1},
        "multi": true,
        "includeAll": true,
        "current": {"selected": false, "text": "All", "value": "$__all"},
        "refresh": 2
      },
      {
        "name": "search",
        "label": "Search text",
        "type": "textbox",
        "current": {"selected": false, "text": "", "value": ""}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log volume by service",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "loki", "uid": "loki"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}, "custom": {"drawStyle": "bars", "stacking": {"mode": "normal"}, "fillOpacity": 80}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\", env=~\"$env\"} |= \"$search\" [$__interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Errors per second by service",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "fieldConfig": {"defaults": {"unit": "logs/s", "color": {"mode": "palette-classic"}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\"$service\", env=~\"$env\", level=~\"error|critical|fatal\"} |= \"$search\" [$__rate_interval]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP status codes (edge Caddy access logs)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}, "custom": {"drawStyle": "bars", "stacking": {"mode": "normal"}, "fillOpacity": 80}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum by (status) (count_over_time({job=\"caddy_edge_access\"}[$__interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Live tail",
      "type": "logs",
      "gridPos": {"h": 16, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "loki", "uid": "loki"},
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{service=~\"$service\", env=~\"$env\"} |= \"$search\"",
          "refId": "A"
        }
      ]
    }
  ]
}
