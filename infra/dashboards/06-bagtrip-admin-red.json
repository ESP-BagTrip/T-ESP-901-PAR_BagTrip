{
  "annotations": {"list": []},
  "description": "Health dashboard for the BagTrip Next.js admin: Node.js process metrics from prom-client (collectDefaultMetrics). Phase 3 will add per-route RED via OpenTelemetry.",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "schemaVersion": 39,
  "tags": ["bagtrip", "admin", "nodejs"],
  "time": {"from": "now-3h", "to": "now"},
  "timezone": "browser",
  "title": "BagTrip — Admin (Next.js)",
  "uid": "bagtrip-admin-red",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Environment",
        "type": "custom",
        "query": "prod, preprod",
        "current": {"selected": false, "text": "prod", "value": "prod"},
        "options": [
          {"selected": true, "text": "prod", "value": "prod"},
          {"selected": false, "text": "preprod", "value": "preprod"}
        ]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU usage (process)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percent", "color": {"mode": "palette-classic"}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "rate(process_cpu_user_seconds_total{job=\"bagtrip-admin\", env=\"$env\"}[5m]) * 100",
          "legendFormat": "user",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_system_seconds_total{job=\"bagtrip-admin\", env=\"$env\"}[5m]) * 100",
          "legendFormat": "system",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memory (heap + RSS)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "palette-classic"}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "nodejs_heap_size_used_bytes{job=\"bagtrip-admin\", env=\"$env\"}", "legendFormat": "heap used", "refId": "A"},
        {"expr": "nodejs_heap_size_total_bytes{job=\"bagtrip-admin\", env=\"$env\"}", "legendFormat": "heap total", "refId": "B"},
        {"expr": "process_resident_memory_bytes{job=\"bagtrip-admin\", env=\"$env\"}", "legendFormat": "rss", "refId": "C"}
      ]
    },
    {
      "id": 3,
      "title": "Event loop lag",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "nodejs_eventloop_lag_seconds{job=\"bagtrip-admin\", env=\"$env\"}", "legendFormat": "lag", "refId": "A"},
        {"expr": "nodejs_eventloop_lag_p99_seconds{job=\"bagtrip-admin\", env=\"$env\"}", "legendFormat": "p99", "refId": "B"}
      ]
    },
    {
      "id": 4,
      "title": "GC pause duration",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "palette-classic"}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum{job=\"bagtrip-admin\", env=\"$env\"}[5m]) / rate(nodejs_gc_duration_seconds_count{job=\"bagtrip-admin\", env=\"$env\"}[5m])",
          "legendFormat": "{{kind}} avg",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active handles",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "nodejs_active_handles_total{job=\"bagtrip-admin\", env=\"$env\"}", "legendFormat": "handles", "refId": "A"},
        {"expr": "nodejs_active_requests_total{job=\"bagtrip-admin\", env=\"$env\"}", "legendFormat": "requests", "refId": "B"}
      ]
    },
    {
      "id": 6,
      "title": "Admin up",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [{"options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}, "type": "value"}],
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "options": {"colorMode": "value", "graphMode": "none", "textMode": "value"},
      "targets": [{"expr": "up{job=\"bagtrip-admin\", env=\"$env\"}", "refId": "A"}]
    },
    {
      "id": 7,
      "title": "Uptime",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 20},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 60}]}}},
      "options": {"colorMode": "value", "graphMode": "none", "textMode": "value"},
      "targets": [{"expr": "max(time() - process_start_time_seconds{job=\"bagtrip-admin\", env=\"$env\"})", "refId": "A"}]
    },
    {
      "id": 8,
      "title": "Open file descriptors",
      "type": "stat",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "options": {"colorMode": "value", "graphMode": "area", "textMode": "value"},
      "targets": [{"expr": "process_open_fds{job=\"bagtrip-admin\", env=\"$env\"}", "refId": "A"}]
    }
  ]
}
