# {{ ansible_managed }}
# Postgres + Redis alerts — exporters' data.

groups:
  - name: bagtrip_postgres
    interval: 30s
    rules:
      - alert: PostgresDown
        expr: up{job="postgres"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Postgres {{ '{{ $labels.env }}' }} is DOWN"
          runbook_url: "https://github.com/ESP-BagTrip/T-ESP-901-PAR_BagTrip/blob/develop/infra/runbooks/postgres-down.md"

      - alert: PostgresHighConnectionUtilisation
        expr: |
          (
            sum by (env) (pg_stat_database_numbackends)
            /
            sum by (env) (pg_settings_max_connections)
          ) > 0.8
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Postgres {{ '{{ $labels.env }}' }} > 80% of max_connections used"
          runbook_url: "https://github.com/ESP-BagTrip/T-ESP-901-PAR_BagTrip/blob/develop/infra/runbooks/postgres-down.md"

  # ---- Restic backup freshness (Phase 6) ----
  - name: bagtrip_backups
    interval: 1m
    rules:
      - alert: ResticBackupStale
        expr: |
          time() - max by (target) (restic_last_successful_backup_timestamp) > 26 * 3600
        for: 30m
        labels:
          severity: critical
        annotations:
          summary: "Restic backup for {{ '{{ $labels.target }}' }} is older than 26 hours"
          description: "The nightly backup hasn't reported success in over a day. Investigate the restic-backup.service journal."
          runbook_url: "https://github.com/ESP-BagTrip/T-ESP-901-PAR_BagTrip/blob/develop/infra/runbooks/backup-stale.md"

      - alert: ResticBackupFailed
        expr: restic_last_backup_status == 0
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: "Last restic backup for {{ '{{ $labels.target }}' }} reported a failure"
          runbook_url: "https://github.com/ESP-BagTrip/T-ESP-901-PAR_BagTrip/blob/develop/infra/runbooks/backup-stale.md"

      - alert: ResticRestoreDrillFailed
        expr: restic_last_restore_test_status == 0
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: "Weekly restic restore drill FAILED for {{ '{{ $labels.target }}' }}"
          description: "Backups are written but the restore path is broken. Treat as a real outage of confidence."
          runbook_url: "https://github.com/ESP-BagTrip/T-ESP-901-PAR_BagTrip/blob/develop/infra/runbooks/backup-stale.md"

  - name: bagtrip_redis
    interval: 30s
    rules:
      - alert: RedisDown
        expr: up{job="redis"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Redis {{ '{{ $labels.env }}' }} is DOWN"
          runbook_url: "https://github.com/ESP-BagTrip/T-ESP-901-PAR_BagTrip/blob/develop/infra/runbooks/redis-down.md"

      - alert: RedisMemoryPressure
        # Same `> 0` guard as ContainerMemoryPressure: redis_memory_max_bytes
        # is 0 when no maxmemory is configured, which would otherwise yield
        # +Inf and page on every Redis instance.
        expr: |
          (
            redis_memory_used_bytes
            /
            (redis_memory_max_bytes > 0)
          ) > 0.85
        for: 15m
        labels:
          severity: warning
        annotations:
          summary: "Redis {{ '{{ $labels.env }}' }} memory > 85% of maxmemory"
          runbook_url: "https://github.com/ESP-BagTrip/T-ESP-901-PAR_BagTrip/blob/develop/infra/runbooks/redis-down.md"
