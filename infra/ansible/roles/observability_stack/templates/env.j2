# {{ ansible_managed }}
# Secrets for the observability stack on /opt/observability.
# Owned by deploy:deploy, mode 0600. Never commit to git.

GF_ADMIN_USER={{ observability_grafana_admin_user }}
GF_ADMIN_PASSWORD={{ grafana_admin_password }}

BAGTRIP_PROD_PG_USER={{ bagtrip_prod_pg_user }}
BAGTRIP_PROD_PG_PASSWORD={{ bagtrip_prod_pg_password }}
BAGTRIP_PROD_PG_DB={{ bagtrip_prod_pg_db }}

BAGTRIP_PREPROD_PG_USER={{ bagtrip_preprod_pg_user }}
BAGTRIP_PREPROD_PG_PASSWORD={{ bagtrip_preprod_pg_password }}
BAGTRIP_PREPROD_PG_DB={{ bagtrip_preprod_pg_db }}

# Phase 6 — Restic backup credentials (sourced by /opt/observability/scripts/).
RESTIC_PASSWORD={{ restic_password }}
{% if observability_restic_b2_account_id and observability_restic_b2_account_key %}
B2_ACCOUNT_ID={{ observability_restic_b2_account_id }}
B2_ACCOUNT_KEY={{ observability_restic_b2_account_key }}
{% endif %}

# Phase 1c — bcrypt hash for the grafana.bagtrip.fr basic_auth, persisted
# so the Caddy vhost blockinfile task stays idempotent across runs.
{% if grafana_basic_auth_hash_value is defined %}
GRAFANA_BASIC_AUTH_HASH={{ grafana_basic_auth_hash_value }}
{% endif %}
