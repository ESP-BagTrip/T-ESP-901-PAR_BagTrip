# {{ ansible_managed }}
# Blackbox exporter modules.

modules:
  http_2xx:
    prober: http
    timeout: 5s
    http:
      preferred_ip_protocol: ip4
      valid_status_codes: [200, 301, 302, 401, 403]
      follow_redirects: true
      fail_if_ssl: false
      fail_if_not_ssl: false

  tcp_tls:
    prober: tcp
    timeout: 5s
    tcp:
      tls: true
      preferred_ip_protocol: ip4
