# {{ ansible_managed }}
# BagTrip observability stack — Phase 1a (metrics layer).
# Logs (Loki) and traces (Tempo) are added in Phase 2 and Phase 3.

name: observability

services:
  prometheus:
    image: prom/prometheus:{{ observability_versions.prometheus }}
    container_name: observability-prometheus
    restart: unless-stopped
    user: "65534:65534"
    extra_hosts:
      - "host.docker.internal:host-gateway"
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus
      - --storage.tsdb.retention.time={{ observability_prometheus_retention_time }}
      - --storage.tsdb.retention.size={{ observability_prometheus_retention_size }}
      - --web.enable-lifecycle
      - --web.console.libraries=/usr/share/prometheus/console_libraries
      - --web.console.templates=/usr/share/prometheus/consoles
    volumes:
      # Mount the directory (not the file) so atomic replaces (Ansible
      # template tasks write+rename) propagate into the container.
      - ./prometheus:/etc/prometheus:ro
      - prometheus_data:/prometheus
    ports:
      - "127.0.0.1:{{ observability_prometheus_host_port }}:9090"
    # Multi-homed: scrapes app /metrics directly via Docker DNS on the
    # bagtrip stack networks (Phase 1b). Adjacent unrelated stacks are
    # NOT joined.
    networks:
      - default
      - bagtrip_prod
      - bagtrip_preprod

  grafana:
    image: grafana/grafana:{{ observability_versions.grafana }}
    container_name: observability-grafana
    restart: unless-stopped
    user: "472:472"
    env_file: .env
    environment:
      GF_SECURITY_ADMIN_USER: ${GF_ADMIN_USER}
      GF_SECURITY_ADMIN_PASSWORD: ${GF_ADMIN_PASSWORD}
      GF_USERS_ALLOW_SIGN_UP: "false"
      GF_AUTH_ANONYMOUS_ENABLED: "false"
      GF_INSTALL_PLUGINS: ""
      GF_SERVER_HTTP_PORT: "3000"
      GF_FEATURE_TOGGLES_ENABLE: ""
    volumes:
      - ./grafana/provisioning:/etc/grafana/provisioning:ro
      - ./grafana/dashboards:/var/lib/grafana/dashboards:ro
      - grafana_data:/var/lib/grafana
    ports:
      - "127.0.0.1:{{ observability_grafana_host_port }}:3000"
    depends_on: [prometheus]
    networks: [default]

  node_exporter:
    image: prom/node-exporter:{{ observability_versions.node_exporter }}
    container_name: observability-node-exporter
    restart: unless-stopped
    # Bridge network + /:/host mount + pid:host gives node_exporter full
    # visibility on the host while staying scrape-able from Prometheus via
    # Docker DNS (node_exporter:9100). Avoids the loopback-binding trap of
    # `network_mode: host`.
    pid: host
    volumes:
      - /:/host:ro,rslave
    command:
      - --path.rootfs=/host
      - --collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc|var/lib/docker)($$|/)
      - --collector.filesystem.fs-types-exclude=^(autofs|binfmt_misc|bpf|cgroup2?|configfs|debugfs|devpts|devtmpfs|fusectl|hugetlbfs|iso9660|mqueue|nsfs|overlay|proc|procfs|pstore|rpc_pipefs|securityfs|selinuxfs|squashfs|sysfs|tracefs)$$
      - --web.listen-address=0.0.0.0:9100
    networks: [default]

  cadvisor:
    image: gcr.io/cadvisor/cadvisor:{{ observability_versions.cadvisor }}
    container_name: observability-cadvisor
    restart: unless-stopped
    privileged: true
    command:
      - --housekeeping_interval=30s
      - --docker_only=true
      - --store_container_labels=false
      - --disable_metrics=disk,referenced_memory,udp,tcp,advtcp,sched,process,hugetlb
    volumes:
      # /var/lib/docker is intentionally NOT mounted: Docker 28+ moved the
      # layerdb format and older cAdvisor builds spam errors. cAdvisor still
      # gets per-container cgroup metrics via /sys + Docker engine API.
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /dev/disk:/dev/disk:ro
    networks: [default]

  postgres_exporter_prod:
    image: prometheuscommunity/postgres-exporter:{{ observability_versions.postgres_exporter }}
    container_name: observability-postgres-exporter-prod
    restart: unless-stopped
    env_file: .env
    environment:
      DATA_SOURCE_NAME: "postgresql://${BAGTRIP_PROD_PG_USER}:${BAGTRIP_PROD_PG_PASSWORD}@{{ observability_bagtrip_prod_postgres_container }}:5432/${BAGTRIP_PROD_PG_DB}?sslmode=disable"
    networks:
      - default
      - bagtrip_prod

  postgres_exporter_preprod:
    image: prometheuscommunity/postgres-exporter:{{ observability_versions.postgres_exporter }}
    container_name: observability-postgres-exporter-preprod
    restart: unless-stopped
    env_file: .env
    environment:
      DATA_SOURCE_NAME: "postgresql://${BAGTRIP_PREPROD_PG_USER}:${BAGTRIP_PREPROD_PG_PASSWORD}@{{ observability_bagtrip_preprod_postgres_container }}:5432/${BAGTRIP_PREPROD_PG_DB}?sslmode=disable"
    networks:
      - default
      - bagtrip_preprod

  redis_exporter_prod:
    image: oliver006/redis_exporter:{{ observability_versions.redis_exporter }}
    container_name: observability-redis-exporter-prod
    restart: unless-stopped
    command:
      - --redis.addr=redis://{{ observability_bagtrip_prod_redis_container }}:6379
    networks:
      - default
      - bagtrip_prod

  redis_exporter_preprod:
    image: oliver006/redis_exporter:{{ observability_versions.redis_exporter }}
    container_name: observability-redis-exporter-preprod
    restart: unless-stopped
    command:
      - --redis.addr=redis://{{ observability_bagtrip_preprod_redis_container }}:6379
    networks:
      - default
      - bagtrip_preprod

  blackbox_exporter:
    image: prom/blackbox-exporter:{{ observability_versions.blackbox_exporter }}
    container_name: observability-blackbox-exporter
    restart: unless-stopped
    volumes:
      - ./blackbox:/etc/blackbox_exporter:ro
    networks: [default]

  loki:
    image: grafana/loki:{{ observability_versions.loki }}
    container_name: observability-loki
    restart: unless-stopped
    user: "10001:10001"
    command:
      - -config.file=/etc/loki/local-config.yaml
    volumes:
      - ./loki:/etc/loki:ro
      - loki_data:/loki
    ports:
      - "127.0.0.1:3100:3100"
    networks: [default]

  promtail:
    image: grafana/promtail:{{ observability_versions.promtail }}
    container_name: observability-promtail
    restart: unless-stopped
    command:
      - -config.file=/etc/promtail/config.yml
    volumes:
      - ./promtail:/etc/promtail:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /var/log:/var/log:ro
      - /opt/edge/logs:/edge_logs:ro
      - promtail_data:/var/lib/promtail
    depends_on: [loki]
    networks: [default]

  tempo:
    image: grafana/tempo:{{ observability_versions.tempo }}
    container_name: observability-tempo
    restart: unless-stopped
    user: "10001:10001"
    command:
      - -config.file=/etc/tempo/tempo.yaml
    volumes:
      - ./tempo:/etc/tempo:ro
      - tempo_data:/var/tempo
    # Multi-homed on the BagTrip stack networks so api containers reach the
    # OTLP receivers as `tempo:4317`. Same pattern as prometheus.
    networks:
      - default
      - bagtrip_prod
      - bagtrip_preprod

volumes:
  prometheus_data:
  grafana_data:
  loki_data:
  promtail_data:
  tempo_data:

networks:
  default:
    name: observability_default
  bagtrip_prod:
    external: true
    name: {{ observability_bagtrip_prod_network }}
  bagtrip_preprod:
    external: true
    name: {{ observability_bagtrip_preprod_network }}
