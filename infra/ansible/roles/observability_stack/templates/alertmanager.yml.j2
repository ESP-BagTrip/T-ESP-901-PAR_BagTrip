# {{ ansible_managed }}
# Alertmanager — Phase 4. Routes alerts by severity. The Discord webhook is
# optional: leaving observability_alertmanager_discord_webhook empty makes
# every route fall back to the `null` receiver so deployments succeed even
# without channel credentials configured.

global:
  resolve_timeout: {{ observability_alertmanager_resolve_timeout }}

route:
  # Default group: bundle alerts by alertname + severity within 30s windows.
  group_by: [alertname, severity]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: default
  routes:
    - matchers:
        - severity = critical
      receiver: pager
      group_wait: 10s
      repeat_interval: 1h
      continue: true
    - matchers:
        - severity = warning
      receiver: ticket
      continue: true
    - matchers:
        - severity = info
      receiver: 'null'

inhibit_rules:
  # If a critical fires for a given target, swallow lower-severity alerts
  # on the same target — one notification per real outage.
  - source_matchers:
      - severity = critical
    target_matchers:
      - severity =~ "warning|info"
    equal: [alertname, instance]

receivers:
  - name: 'null'

  - name: default
{% if observability_alertmanager_discord_webhook %}
    discord_configs:
      - webhook_url: "{{ observability_alertmanager_discord_webhook }}"
        send_resolved: true
        title: '[{{ '{{ .Status | toUpper }}' }}{{ '{{ if eq .Status "firing" }}:{{ .Alerts.Firing | len }}{{ end }}' }}] {{ '{{ .CommonLabels.alertname }}' }}'
        message: |
          {{ '{{ range .Alerts }}' }}
          *{{ '{{ .Labels.severity | toUpper }}' }}* — {{ '{{ .Labels.alertname }}' }}
          {{ '{{ if .Labels.instance }}Instance: `{{ .Labels.instance }}`{{ end }}' }}
          {{ '{{ if .Annotations.summary }}{{ .Annotations.summary }}{{ end }}' }}
          {{ '{{ if .Annotations.runbook_url }}Runbook: {{ .Annotations.runbook_url }}{{ end }}' }}
          {{ '{{ end }}' }}
{% else %}
    # No webhook configured — alerts visible only via Alertmanager UI.
    webhook_configs: []
{% endif %}

  - name: pager
{% if observability_alertmanager_discord_webhook %}
    discord_configs:
      - webhook_url: "{{ observability_alertmanager_discord_webhook }}"
        send_resolved: true
{% else %}
    webhook_configs: []
{% endif %}

  - name: ticket
{% if observability_alertmanager_discord_webhook %}
    discord_configs:
      - webhook_url: "{{ observability_alertmanager_discord_webhook }}"
        send_resolved: true
{% else %}
    webhook_configs: []
{% endif %}
